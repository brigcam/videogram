TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional: comma-separated Telegram chat IDs allowed to use the bot.
# Empty means every group/supergroup chat is allowed.
ALLOWED_CHAT_IDS=

# Optional: comma-separated Telegram user IDs allowed to use the bot in private.
# Empty means every private user is allowed.
ALLOWED_USER_IDS=

# Optional: generate a cached summary when a transcript/subtitle is available.
# Leave OPENAI_API_KEY empty to disable summaries.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5.2
OPENAI_SUMMARY_PROMPT=Riassumi la trascrizione del video in italiano, in modo utile e conciso. Evidenzia i punti principali e conserva eventuali dettagli concreti importanti.
OPENAI_SUMMARY_MAX_TRANSCRIPT_CHARS=20000
SUMMARY_TRANSCRIPT_LANGS=it,en

# Optional tuning
MAX_DOWNLOAD_MB=48
DOWNLOAD_DIR=/tmp/videogram-downloads
MIN_FREE_DISK_PERCENT=5
LOG_LEVEL=INFO
LOG_FILE=/var/log/videogram/videogram.log
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5

# Optional: export cookies as Netscape cookies.txt files and mount them here.
# Files like /cookies/youtube.txt, reddit.txt, instagram.txt, facebook.txt, threads.txt and x.txt are merged at runtime.
# YTDLP_COOKIES_FILE=/cookies/youtube.txt
YTDLP_COOKIES_DIR=/cookies
