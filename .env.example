TELEGRAM_BOT_TOKEN=123456:replace-me

# Optional: self-hosted Telegram Bot API server.
# Create api_id/api_hash at https://my.telegram.org -> API development tools.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_API_LOCAL=1
# Enable these after starting the local Bot API profile.
# TELEGRAM_API_BASE_URL=http://telegram-bot-api:8081/bot
# TELEGRAM_API_FILE_BASE_URL=http://telegram-bot-api:8081/file/bot
# TELEGRAM_LOCAL_MODE=true

# Optional: comma-separated Telegram chat IDs allowed to use the bot.
# Empty means every group/supergroup chat is allowed.
ALLOWED_CHAT_IDS=

# Optional: comma-separated Telegram user IDs allowed to use the bot in private.
# Empty means every private user is allowed.
ALLOWED_USER_IDS=

# Optional: /usage command and private usage reports.
# /usage only works in private chats for USAGE_ALLOWED_USER_IDS.
USAGE_ALLOWED_USER_IDS=
# Optional: /cookie command in private chats. Empty means inherit USAGE_ALLOWED_USER_IDS.
COOKIE_ALLOWED_USER_IDS=
COOKIE_ALERT_USER_ID=123456789
USAGE_REPORT_USER_ID=
USAGE_CHECK_INTERVAL_MINUTES=60
USAGE_ALERT_STEP_PERCENT=10
USAGE_ALERT_STATE_FILE=/var/log/videogram/usage-alerts.json

# Optional: Hetzner Cloud usage metrics.
HETZNER_API_TOKEN=
HETZNER_SERVER_ID=
HETZNER_MONTHLY_TRAFFIC_TB=20

# Optional: OpenAI organization costs. Requires an OpenAI Admin key.
OPENAI_ADMIN_KEY=
OPENAI_MONTHLY_BUDGET_USD=0

# Optional: generate a cached summary when a transcript/subtitle or post description is available.
# Leave OPENAI_API_KEY empty to disable summaries.
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5-mini
OPENAI_SUMMARY_PROMPT="Riassumi il contenuto in italiano in pochi punti concisi, scegliendo solo quelli davvero importanti. Evidenzia i punti principali e conserva eventuali dettagli concreti importanti."
OPENAI_SUMMARY_MAX_TRANSCRIPT_CHARS=20000
SUMMARY_TRANSCRIPT_LANGS=it,en

# Optional tuning
MAX_DOWNLOAD_MB=512
MAX_TELEGRAM_UPLOAD_MB=48
DOWNLOAD_DIR=/tmp/videogram-downloads
MIN_FREE_DISK_PERCENT=5
MAX_CONCURRENT_JOBS=2
SITE_CONCURRENT_JOBS=1
LOG_LEVEL=INFO
LOG_FILE=/var/log/videogram/videogram.log
LOG_MAX_MB=10
LOG_BACKUP_COUNT=5
FAILED_LINKS_FILE=/var/log/videogram/failed-links.jsonl

# Optional: export cookies as Netscape cookies.txt files and mount them here.
# Files like /cookies/youtube.txt, reddit.txt, instagram.txt, facebook.txt, threads.txt, x.txt and tiktok.txt are selected by domain at runtime.
# YTDLP_COOKIES_FILE=/cookies/youtube.txt
YTDLP_COOKIES_DIR=/cookies
BROWSER_PROFILE_DIR=/browser-profiles
BROWSER_CHROMIUM_EXECUTABLE=/usr/bin/chromium
